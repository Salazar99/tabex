{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug: 'Tabex'",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/dotparser/tabex.py",
            "args": [
                "${workspaceFolder}/m_stlsat/resources/benchmarks/Metrictrials/example1.stl",
                "./output.txt"               
            ],
            "console": "integratedTerminal"
        },
        {
            "sourceLanguages": [
                "rust"
            ],
            "name": "Debug 'stlsat'",
            "type": "lldb",
            "cwd": "${workspaceFolder}/m_stlsat",
            "request": "launch",
            "program": "${workspaceFolder}/m_stlsat/target/debug/stlsat",
            "preLaunchTask": "cargo build",
            "args": [
                "${workspaceFolder}/m_stlsat/resources/benchmarks/Metrictrials/example1.stl",
                "--graph-output",
                "graph_F.dot",
                "--no-jump-rule",
                "--no-formula-simplifications",
                "--no-formula-optimizations"
            ],
        }
    ]
}