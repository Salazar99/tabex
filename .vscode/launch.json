{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug: 'complete'",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/run_similarity.py",
            "args": [
                "F[0,2](x>0)",
                "F[3,4](x>0)"
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "Debug: 'Similarity'",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/similarity/stl_similarity.py",
            "args": [
                "./output_F.json",
                "./output_F_or.json"
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "Debug: 'input_creator'",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/dotparser/input_creator.py",
            "args": [
                "${workspaceFolder}/m_stlsat/resources/benchmarks/Metrictrials/example1.stl",
                "./output_F_or.json"               
            ],
            "console": "integratedTerminal"
        },
        {
            "sourceLanguages": [
                "rust"
            ],
            "name": "Debug 'stlsat'",
            "type": "lldb",
            "cwd": "${workspaceFolder}/m_stlsat",
            "request": "launch",
            "program": "${workspaceFolder}/m_stlsat/target/debug/stlsat",
            "preLaunchTask": "cargo build",
            "args": [
                "${workspaceFolder}/m_stlsat/resources/benchmarks/Metrictrials/example1.stl",
                "--graph-output",
                "graph_F.dot",
                "--no-jump-rule",
                "--no-formula-simplifications",
                "--no-formula-optimizations"
            ],
        }
    ]
}